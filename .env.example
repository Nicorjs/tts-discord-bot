# Token del bot (Discord Developer Portal > tu app > Bot > Reset Token)
DISCORD_TOKEN=

# ID del canal de TEXTO que el bot va a leer en voz alta
# (activa "Modo desarrollador" en Discord: Ajustes > Avanzado, luego clic derecho al canal > "Copiar ID")
TEXT_CHANNEL_ID=

# Voz a usar por defecto (opcional). Se puede cambiar en vivo con el comando !voz.
# Ejecuta "npm run voices" para ver todas las voces en español.
VOICE_NAME=es-ES-AlvaroNeural

# Máximo de caracteres que se leen por mensaje (opcional)
MAX_CHARS=400

# Milisegundos que espera el bot solo en el canal antes de salir (opcional)
LEAVE_DELAY_MS=60000

# Prefijo de los comandos de chat, ej. !voz, !vozlista, !ayuda (opcional)
COMMAND_PREFIX=!

# --- Solo necesarias si usas el contenedor "deploy-watcher" (auto-deploy) ---

# Ruta ABSOLUTA donde clonaste este repo en el VPS. Debe coincidir exactamente
# con la ruta real en el host (ej. /opt/discord-tts-bot). La obtienes con "pwd"
# parado dentro de la carpeta del repo en el VPS.
HOST_REPO_PATH=

# Cada cuántos segundos el watcher revisa si hay cambios en GitHub (opcional)
DEPLOY_INTERVAL_SECONDS=300

# Rama que vigila el watcher (opcional)
DEPLOY_BRANCH=main
